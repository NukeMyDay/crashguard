DATABASE_URL=postgres://marketpulse:marketpulse@localhost:5432/marketpulse
PORT=3000
FRED_API_KEY=your_fred_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here  # optional: set via Settings page instead
ENCRYPTION_SECRET=change-me-to-a-long-random-secret  # used to encrypt API keys at rest

# Optional: SMTP delivery for daily digest email
SMTP_HOST=                    # e.g. smtp.sendgrid.net — leave blank to disable email
SMTP_USER=                    # SMTP username
SMTP_PASS=                    # SMTP password
DIGEST_EMAIL=                 # recipient email address for daily digest
